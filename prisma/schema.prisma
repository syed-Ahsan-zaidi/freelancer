generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          Role      @default(CLIENT) 
  bio           String?   @default("Research Collaborator") 
  image         String?   
  createdAt     DateTime  @default(now())
  
  // Relations
  projects      Project[] // Projects managed by this user
  ownedClient   Client?   @relation("UserToClient") // Agar user ek client hai
  
  emailNotify   Boolean   @default(true)
  desktopNotify Boolean   @default(true)
  inquiryNotify Boolean   @default(true)
}

model Client {
  id        String    @id @default(cuid())
  name      String
  email     String?   @unique
  
  // Mentor's Logic: Connecting Client to a User Account
  userId    String?   @unique
  user      User?     @relation("UserToClient", fields: [userId], references: [id])

  projects  Project[]
  invoices  Invoice[]
  
  // Real-life data: Company details
  company   String?
  address   String?
  createdAt DateTime  @default(now())
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  budget      Float?
  category    String    @default("Web Development")
  image       String?
  
  // Progress tracking
  progress    Int       @default(0) // 0 to 100%
  
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  tasks       Task[]
  invoices    Invoice[]
  research    ResearchData[] // Searchable research papers/data
  
  createdAt   DateTime  @default(now())
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("TODO")
  priority    String    @default("MEDIUM")
  dueDate     DateTime?
  price       Float?    // Invoice amount jab task complete ho

  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
}

// Mentor's Requirement: Searchable Data
model ResearchData {
  id          String   @id @default(cuid())
  title       String
  content     String   // The actual research text or summary
  fileUrl     String?  // Link to PDF/Image
  tags        String[] // For easy searching
  
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model Invoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique // e.g., INV-001
  amount      Float
  tax         Float    @default(0)
  total       Float
  status      String   @default("UNPAID") // UNPAID, PAID, OVERDUE
  
  dueDate     DateTime
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String   // INVOICE, TASK, PROJECT
  isRead    Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())
}